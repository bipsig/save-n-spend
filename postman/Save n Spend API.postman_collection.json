    {
      "name": "Transactions",
      "description": "The balance engine: every create/edit/delete atomically moves account balances inside a Mongo transaction.\n- expense: −amount on `account`\n- income: +amount on `account`\n- transfer: −amount on `account`, +amount on `toAccount` (ONE document)\n- positiveAdjustment / negativeAdjustment: ±amount on `account` (reconciliation; excluded from spending insights)\n\n`amount` is always positive integer paise. `type` is immutable after creation.",
      "item": [
        {
          "name": "List transactions (filters + pagination)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/transactions?page=1&limit=20",
              "host": ["{{BASE_URL}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "1", "description": "Default 1" },
                { "key": "limit", "value": "20", "description": "Default 20, max 100" },
                { "key": "type", "value": "expense", "description": "expense | income | transfer", "disabled": true },
                { "key": "category", "value": "{{categoryId}}", "description": "Filtering by a parent automatically includes its children", "disabled": true },
                { "key": "search", "value": "starbucks", "description": "Case-insensitive title regex", "disabled": true },
                { "key": "startDate", "value": "2026-07-01", "description": "ISO date — must be paired with endDate", "disabled": true },
                { "key": "endDate", "value": "2026-07-31", "description": "ISO date — must be paired with startDate", "disabled": true }
              ]
            },
            "description": "Paginated (mongoose-paginate-v2) — `data.docs` holds the rows, plus `totalDocs/page/limit/totalPages/hasNextPage/...`.\n\nGotchas:\n- Query values are NOT quoted: `?type=income`, never `?type=\"income\"`.\n- `startDate`/`endDate` must be sent together (single one → 400).\n- `category` is a plain id in each doc (no populate) — the client resolves names from its own store."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{BASE_URL}}/transactions?page=1&limit=20", "host": ["{{BASE_URL}}"], "path": ["transactions"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "20" }] } },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"statusCode\": 200,\n  \"message\": \"Transactions fetched\",\n  \"data\": {\n    \"docs\": [\n      {\n        \"_id\": \"6a5fcad5abf73860c118ea63\",\n        \"userId\": \"6a568001927536ee5cba3c9d\",\n        \"type\": \"expense\",\n        \"amount\": 45000,\n        \"account\": \"6a568002927536ee5cba3cbd\",\n        \"category\": \"6a568001927536ee5cba3c9f\",\n        \"title\": \"Starbucks\",\n        \"occurredAt\": \"2026-07-21T14:30:00.000Z\",\n        \"createdAt\": \"2026-07-21T14:30:01.534Z\",\n        \"updatedAt\": \"2026-07-21T14:30:01.534Z\"\n      }\n    ],\n    \"totalDocs\": 43,\n    \"limit\": 20,\n    \"page\": 1,\n    \"totalPages\": 3,\n    \"hasNextPage\": true,\n    \"hasPrevPage\": false,\n    \"nextPage\": 2,\n    \"prevPage\": null\n  }\n}"
            }
          ]
        },
        {
          "name": "Create expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 201 && json?.data?._id) {",
                  "  pm.collectionVariables.set('transactionId', json.data._id);",
                  "  console.log('transactionId saved:', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expense\",\n  \"amount\": 45000,\n  \"account\": \"{{accountId}}\",\n  \"category\": \"{{categoryId}}\",\n  \"title\": \"Starbucks\",\n  \"note\": \"Cold brew with friends\",\n  \"location\": \"Connaught Place\",\n  \"paymentMode\": \"upi\",\n  \"occurredAt\": \"2026-07-21T14:30:00.000Z\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] },
            "description": "expense/income branch (discriminated union): requires `account`, `category`, `title`. Optional: `note`, `location`, `receiptUrl`, `paymentMode` (cash|upi|card|transfer), `occurredAt` (ISO — server stamps now when omitted).\n\n₹450 = 45000 paise, debited from the account atomically.\n\nTest script saves `data._id` → `{{transactionId}}`."
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] } },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"statusCode\": 201,\n  \"message\": \"Transaction created!\",\n  \"data\": {\n    \"_id\": \"6a5fcad5abf73860c118ea63\",\n    \"userId\": \"6a568001927536ee5cba3c9d\",\n    \"type\": \"expense\",\n    \"amount\": 45000,\n    \"account\": \"6a568002927536ee5cba3cbd\",\n    \"category\": \"6a568001927536ee5cba3c9f\",\n    \"title\": \"Starbucks\",\n    \"note\": \"Cold brew with friends\",\n    \"location\": \"Connaught Place\",\n    \"paymentMode\": \"upi\",\n    \"occurredAt\": \"2026-07-21T14:30:00.000Z\"\n  }\n}"
            },
            {
              "name": "400 Bad Request (account not found / archived)",
              "originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] } },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"statusCode\": 400,\n  \"message\": \"Account not found\",\n  \"data\": null\n}"
            }
          ]
        },
        {
          "name": "Create income",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"income\",\n  \"amount\": 1500000,\n  \"account\": \"{{accountId}}\",\n  \"category\": \"{{categoryId}}\",\n  \"title\": \"Freelance Project\",\n  \"paymentMode\": \"transfer\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] },
            "description": "Same branch as expense — `type: income` credits the account instead. Use an income-kind category id."
          },
          "response": []
        },
        {
          "name": "Create transfer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"transfer\",\n  \"amount\": 200000,\n  \"account\": \"SOURCE_ACCOUNT_ID\",\n  \"toAccount\": \"DEST_ACCOUNT_ID\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] },
            "description": "Transfer branch: `account` (source) + `toAccount` (destination), NO `category`/`title` (strict — they're rejected). ONE document; the engine debits source and credits destination atomically.\n\nSame-account transfer → 400 \"Cannot transfer to same account\". Replace the placeholder ids with two real account ids."
          },
          "response": [
            {
              "name": "400 Bad Request (same account)",
              "originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] } },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"statusCode\": 400,\n  \"message\": \"Cannot transfer to same account\",\n  \"data\": null\n}"
            }
          ]
        },
        {
          "name": "Create adjustment (reconcile balance)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"positiveAdjustment\",\n  \"amount\": 5000,\n  \"account\": \"{{accountId}}\",\n  \"title\": \"Balance correction\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/transactions", "host": ["{{BASE_URL}}"], "path": ["transactions"] },
            "description": "Adjustment branch: `type` = positiveAdjustment | negativeAdjustment, `account` required, `title` optional, NO category/toAccount.\n\nReconciliation flow: client computes `delta = target − current`; positive delta → positiveAdjustment, negative → negativeAdjustment, `amount = |delta|`. Moves the balance but is auto-excluded from spending insights."
          },
          "response": []
        },
        {
          "name": "Get transaction by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/transactions/{{transactionId}}", "host": ["{{BASE_URL}}"], "path": ["transactions", "{{transactionId}}"] },
            "description": "Ownership-scoped single fetch — powers the mobile Edit prefill. Foreign id → 404."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{BASE_URL}}/transactions/{{transactionId}}", "host": ["{{BASE_URL}}"], "path": ["transactions", "{{transactionId}}"] } },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"statusCode\": 200,\n  \"message\": \"Transaction fetched!\",\n  \"data\": {\n    \"_id\": \"6a5fcad5abf73860c118ea63\",\n    \"userId\": \"6a568001927536ee5cba3c9d\",\n    \"type\": \"expense\",\n    \"amount\": 45000,\n    \"account\": \"6a568002927536ee5cba3cbd\",\n    \"category\": \"6a568001927536ee5cba3c9f\",\n    \"title\": \"Starbucks\",\n    \"occurredAt\": \"2026-07-21T14:30:00.000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Update transaction",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 52000,\n  \"title\": \"Starbucks (corrected)\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/transactions/{{transactionId}}", "host": ["{{BASE_URL}}"], "path": ["transactions", "{{transactionId}}"] },
            "description": "Strict body — editable: `amount`, `account`, `toAccount`, `category`, `title`, `note`, `location`, `receiptUrl`, `paymentMode`, `occurredAt`. **`type` is immutable** (delete + recreate to change kind).\n\nThe engine reverts the OLD effects, applies the NEW ones — balances stay exact. Verify: check the account balance before/after; it should shift by exactly the delta."
          },
          "response": []
        },
        {
          "name": "Delete transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/transactions/{{transactionId}}", "host": ["{{BASE_URL}}"], "path": ["transactions", "{{transactionId}}"] },
            "description": "HARD delete (transactions are leaf records — nothing references them) with a balance revert: the account gets the money back before the doc is removed, atomically."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "DELETE", "header": [], "url": { "raw": "{{BASE_URL}}/transactions/{{transactionId}}", "host": ["{{BASE_URL}}"], "path": ["transactions", "{{transactionId}}"] } },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": true,\n  \"statusCode\": 200,\n  \"message\": \"Transaction Deleted\",\n  \"data\": null\n}"
            }
          ]
        }
      ]
    }
